{
  "rewrites": [
    {
      "source": "/jobs/:role",
      "destination": "/api/seo-jobs?role=:role"
    },
    {
      "source": "/jobs/:role/:location",
      "destination": "/api/seo-jobs?role=:role&location=:location"
    },
    {
      "source": "/((?!sitemap.xml|robots.txt|manifest.json|sw.js|icon-.*\\.png|api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://udyampath.vercel.app"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}